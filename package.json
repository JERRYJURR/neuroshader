{
  "name": "neuroshader-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for neuroshader — the runtime library and the studio editor.",
  "packageManager": "pnpm@11.0.3",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter neuroshader dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules/.vite"
  },
  "engines": {
    "node": ">=18"
  }
}
